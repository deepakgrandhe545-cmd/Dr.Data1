"""
Lightweight LLM Candidate Extractor
-----------------------------------
Scans text columns of a DataFrame, vectorizes unique string profiles,
clusters them via DBSCAN, and flags suspicious values for LLM review.

Anomaly rules:
  1. Short/symbol token        -> "X", "?", "."
  2. Heavy placeholder         -> frequent AND DBSCAN noise (-1)
  3. Rare outlier              -> infrequent AND DBSCAN noise (-1)
  4. Shape outlier             -> shape far from column median (robust z-score)
                                  DISABLED for ID-like columns
  5. Minority anomaly          -> tiny-cardinality column dominated by one value

Skips:
  - Numeric columns (even when stored as text)
  - Shape-rule skipped on ID-like / high-cardinality columns
  - DBSCAN skipped when fewer than 4 unique values

Usage:
    python llm_candidates.py --demo
    python llm_candidates.py --input data.csv --output candidates.csv
"""

from __future__ import annotations

import argparse
import random
from pathlib import Path
from typing import List

import numpy as np
import pandas as pd
from sklearn.cluster import DBSCAN
from sklearn.preprocessing import StandardScaler


# ---------------------------------------------------------------------------
# Feature engineering (shape only - no frequency leakage)
# ---------------------------------------------------------------------------
FEATURE_NAMES = ["length", "word_count", "symbol_ratio",
                 "upper_ratio", "unique_char_ratio"]


def profile_string(s: str) -> List[float]:
    s = str(s)
    n = len(s)
    if n == 0:
        return [0, 0, 1.0, 1.0, 1.0]
    return [
        n,
        len(s.split()),
        sum(not c.isalnum() for c in s) / n,
        sum(c.isupper() for c in s) / n,
        len(set(s)) / n,
    ]


# ---------------------------------------------------------------------------
# Column-type gating
# ---------------------------------------------------------------------------
def is_text_column(series: pd.Series) -> bool:
    return (
        pd.api.types.is_object_dtype(series)
        or pd.api.types.is_string_dtype(series)
        or isinstance(series.dtype, pd.CategoricalDtype)
    )


def is_numeric_like(series: pd.Series, threshold: float = 0.9) -> bool:
    s = series.dropna().astype(str).str.strip()
    if len(s) == 0:
        return False
    return pd.to_numeric(s, errors="coerce").notna().mean() >= threshold


def should_scan(series: pd.Series) -> bool:
    if pd.api.types.is_numeric_dtype(series):
        return False
    return is_text_column(series) and not is_numeric_like(series)


def is_id_like(counts: pd.Series, ratio_threshold: float = 0.3) -> bool:
    """High-cardinality column where most values appear only a few times.
    Typical of IDs, codes, territories, SKUs, etc. Shape rule is suppressed
    for these columns because every value is structurally similar by design."""
    n_unique = len(counts)
    total = int(counts.sum())
    if total == 0:
        return False
    return (n_unique / total) >= ratio_threshold


# ---------------------------------------------------------------------------
# Shape-outlier detector (robust median + MAD, with guards)
# ---------------------------------------------------------------------------
def shape_outlier_mask(features: np.ndarray,
                       z_threshold: float = 3.0,
                       min_unique: int = 4) -> np.ndarray:
    n = features.shape[0]
    if n < min_unique:
        return np.zeros(n, dtype=bool)

    X = StandardScaler().fit_transform(features)
    median = np.median(X, axis=0)
    mad = np.median(np.abs(X - median), axis=0)

    if np.all(mad == 0):
        return np.zeros(n, dtype=bool)

    nonzero = mad[mad > 0]
    mad[mad == 0] = nonzero.min()
    z = np.abs((X - median) / mad).max(axis=1)
    return z > z_threshold


# ---------------------------------------------------------------------------
# Anomaly rules
# ---------------------------------------------------------------------------
def is_minority_anomaly(freq: int, total: int, n_unique: int,
                        dominance_threshold: float = 0.99,
                        max_unique: int = 3) -> bool:
    """In tiny-cardinality columns, flag any value that holds <1% of rows
    when another value holds >=99%."""
    if n_unique > max_unique or total == 0:
        return False
    return (freq / total) <= (1 - dominance_threshold)


def is_suspicious(value, freq, total, cid, shape_odd, minority_odd) -> bool:
    s = str(value)
    short_anomaly     = len(s) <= 3 and (not s.isalnum() or len(s) == 1)
    heavy_placeholder = cid == -1 and freq > max(5, 0.05 * total)
    rare_outlier      = cid == -1 and freq <= max(3, 0.01 * total)
    return (short_anomaly or heavy_placeholder or rare_outlier
            or shape_odd or minority_odd)


def reason_for(value, freq, total, cid, shape_odd, minority_odd) -> str:
    s = str(value)
    reasons = []
    if len(s) <= 3 and (not s.isalnum() or len(s) == 1):
        reasons.append("short/symbol token")
    if cid == -1 and freq > max(5, 0.05 * total):
        reasons.append("heavy placeholder (frequent + DBSCAN noise)")
    if cid == -1 and freq <= max(3, 0.01 * total):
        reasons.append("rare outlier (DBSCAN noise)")
    if shape_odd:
        reasons.append("shape outlier vs column median")
    if minority_odd:
        reasons.append("minority value in dominant-category column")
    return " | ".join(reasons) or "-"


# ---------------------------------------------------------------------------
# Column scanner
# ---------------------------------------------------------------------------
def scan_column(col_name: str, series: pd.Series) -> pd.DataFrame:
    counts = series.astype(str).str.strip().value_counts()
    if len(counts) <= 1:
        return pd.DataFrame()

    total = int(counts.sum())
    n_unique = len(counts)
    id_like = is_id_like(counts)

    features = np.array([profile_string(v) for v in counts.index])
    X = StandardScaler().fit_transform(features)

    # DBSCAN only when there are enough distinct shapes to cluster
    if n_unique >= 4:
        cluster_labels = DBSCAN(eps=0.75, min_samples=2).fit_predict(X)
    else:
        cluster_labels = np.zeros(n_unique, dtype=int)

    # Shape rule is suppressed on ID-like columns
    shape_flags = (np.zeros(n_unique, dtype=bool)
                   if id_like else shape_outlier_mask(features))

    rows = []
    for i, value in enumerate(counts.index):
        freq = int(counts[value])
        cid = int(cluster_labels[i])
        shape_odd = bool(shape_flags[i])
        minority_odd = is_minority_anomaly(freq, total, n_unique)

        if is_suspicious(value, freq, total, cid, shape_odd, minority_odd):
            rows.append({
                "Column_Name": col_name,
                "Unique_Value_To_Check": value,
                "Occurrences_In_Dataset": freq,
                "Cluster_Id": cid,
                "Shape_Outlier": shape_odd,
                "ID_Like_Column": id_like,
                "Reason": reason_for(value, freq, total, cid,
                                     shape_odd, minority_odd),
            })
    return pd.DataFrame(rows)


def extract_unique_candidates_for_llm(df: pd.DataFrame) -> pd.DataFrame:
    frames = [scan_column(c, df[c]) for c in df.columns if should_scan(df[c])]
    frames = [f for f in frames if not f.empty]
    cols = ["Column_Name", "Unique_Value_To_Check", "Occurrences_In_Dataset",
            "Cluster_Id", "Shape_Outlier", "ID_Like_Column", "Reason"]
    if not frames:
        return pd.DataFrame(columns=cols)
    return pd.concat(frames, ignore_index=True)[cols]


# ---------------------------------------------------------------------------
# Demo data
# ---------------------------------------------------------------------------
def build_demo_dataframe(seed: int = 42) -> pd.DataFrame:
    random.seed(seed)
    np.random.seed(seed)

    valid_notes = [
        "Customer requested callback link.",
        "Invoice balance cleared out.",
        "Manager approved priority shipping.",
    ]
    notes = [random.choice(valid_notes) for _ in range(9000)]
    notes += ["Will be updated"] * 1000
    notes += ["X"] * 50

    status_cycle = ["Active", "TBD", "Pending", "Active",
                    "Complete", "???", "Active"]
    status = [status_cycle[i % len(status_cycle)] for i in range(len(notes))]

    bins = []
    for code, n in [("A01", 30), ("A02", 35), ("A03", 47), ("A04", 47),
                    ("A05", 46), ("A06", 33), ("A07", 15),
                    ("B02", 16), ("B03", 21), ("B04", 23), ("B05", 24),
                    ("B06", 22), ("B07", 17),
                    ("C03", 16), ("C04", 22), ("C05", 22), ("C06", 24),
                    ("C07", 17), ("C08", 17)]:
        bins += [code] * n
    bins += ["ahsgfdyufduyv", "jhdvdiuwvcuiwbd"]
    while len(bins) < len(notes):
        bins.append(random.choice(["A01", "A02", "A03"]))
    bins = bins[:len(notes)]

    amounts = [str(round(random.uniform(10, 9999), 2)) for _ in range(len(notes))]
    quantities = np.random.randint(1, 500, size=len(notes))
    products = ["Kisqali"] * (len(notes) - 1) + ["qx7$$zzz"]
    territory = [f"TERR_{i:04d}"
                 for i in np.random.randint(1, 200, size=len(notes))]

    return pd.DataFrame({
        "Notes": notes,
        "Status": status,
        "BinCode": bins,
        "AmountText": amounts,
        "Quantity": quantities,
        "Product": products,
        "Territory_ID": territory,
    })


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------
def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument("--input", type=Path, help="Path to input CSV file")
    p.add_argument("--output", type=Path, default=Path("llm_candidates.csv"),
                   help="Output CSV path (default: llm_candidates.csv)")
    p.add_argument("--demo", action="store_true",
                   help="Run with built-in messy dataset")
    return p.parse_args()


def main() -> None:
    args = parse_args()

    if args.demo or not args.input:
        print("Using built-in demo dataset.")
        df = build_demo_dataframe()
    else:
        print(f"Loading: {args.input}")
        df = pd.read_csv(args.input)

    print(f"   Rows: {len(df):,}   Columns: {list(df.columns)}\n")

    print("Column scan plan:")
    for col in df.columns:
        verdict = "scan" if should_scan(df[col]) else "skip"
        print(f"  [{verdict}] {col:<20} dtype={df[col].dtype}")
    print()

    candidates = extract_unique_candidates_for_llm(df)

    print("-" * 70)
    print(" LIGHTWEIGHT LLM UNIQUE CANDIDATE PAYLOAD")
    print("-" * 70)
    if candidates.empty:
        print("No suspicious values detected.")
    else:
        # Quick summary by column before the full table
        summary = (candidates.groupby("Column_Name")
                             .size()
                             .reset_index(name="Flagged_Count"))
        print("\nSummary by column:")
        print(summary.to_string(index=False))
        print("\nFull candidate list:")
        print(candidates.to_string(index=False))

    candidates.to_csv(args.output, index=False)
    print(f"\nSaved {len(candidates)} candidate(s) -> {args.output.resolve()}")


if __name__ == "__main__":
    main()
